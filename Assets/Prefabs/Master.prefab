    - target: {fileID: 2950478657829309437, guid: 37d31eb3b846be6439ed2769f9acd9e7, type: 3}
      propertyPath: dialogueLines.Array.data[0].text
      value: IT WORKED!
      objectReference: {fileID: 0}
    - target: {fileID: 2950478657829309437, guid: 37d31eb3b846be6439ed2769f9acd9e7, type: 3}
      propertyPath: dialogueLines.Array.data[1].text
      value: Very Impressive...
      objectReference: {fileID: 0}
    - target: {fileID: 2950478657829309437, guid: 37d31eb3b846be6439ed2769f9acd9e7, type: 3}
      propertyPath: dialogueLines.Array.data[2].text
      value: Well, we still have many experiments to run before we call this a success...
      objectReference: {fileID: 0}
    - target: {fileID: 2950478657829309437, guid: 37d31eb3b846be6439ed2769f9acd9e7, type: 3}
      propertyPath: dialogueLines.Array.data[3].text
      value: 'Then let''s go! The cat already got the <b><color=#FFD700>key</color></b>
        and can head for the exit <b><color=#FFD700>in the light.</color></b> '
      objectReference: {fileID: 0}
    - target: {fileID: 2950478657829309437, guid: 37d31eb3b846be6439ed2769f9acd9e7, type: 3}
      propertyPath: dialogueLines.Array.data[4].text
      value: Well, until we <b><color=#FFD700>stop observing. </color></b>
      objectReference: {fileID: 0}
    - target: {fileID: 2950478657829309437, guid: 37d31eb3b846be6439ed2769f9acd9e7, type: 3}
